# Copy to .env and fill in.

# HTTP
PORT=3000
HOST=0.0.0.0

# Storage
DB_PATH=./data/weeber.db

# JWT signing key — generate with: node -e "console.log(crypto.randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-64-bytes-of-hex

# Trial length in days
TRIAL_DAYS=7

# Stripe (optional in dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AppSumo (optional)
APPSUMO_CLIENT_ID=
APPSUMO_CLIENT_SECRET=
