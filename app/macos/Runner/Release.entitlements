<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- NOTE: app-sandbox is intentionally DISABLED for unsigned dev builds.
	     When we ship signed/notarized builds via the Apple Developer Program,
	     re-enable this and add keychain-access-groups + proper provisioning.
	     See HANDOFF.md §15 ("Checklist before public launch") for the full list. -->
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
</dict>
</plist>
